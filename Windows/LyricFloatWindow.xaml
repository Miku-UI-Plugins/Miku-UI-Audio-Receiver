<Window x:Class="Miku_UI_Audio_Receiver.Windows.LyricFloatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Miku_UI_Audio_Receiver.Windows"
        mc:Ignorable="d"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Topmost="True"
        Background="Transparent"
        WindowStyle="None" ResizeMode="NoResize"
        Title="LyricFloatWindow" Height="Auto" MaxHeight="200" Width="Auto" MaxWidth="1500">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>
    <Grid>
        <TextBlock x:Name="LyricText" Text="{StaticResource TbLyricText}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="80" TextAlignment="Center" Foreground="White">
            <TextBlock.Effect>
                <DropShadowEffect
                    BlurRadius="5"
                    Opacity="1"
                    ShadowDepth="0"
                    Color="Black" />
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>
